class Proxy:
    def __init__(self) -> None:
        self.pool: Dict[str, Account] = load_pool()
        self.routes = RouteLRU()           # thread_key -> account_key (affinity)
        self.rr = 0                          # round-robin cursor for tie-breaks
        self.ctrl: Optional[aiohttp.ClientSession] = None  # usage/refresh (decompress)
        self.fwd: Optional[aiohttp.ClientSession] = None   # forwarding (raw bytes)

    # --- account selection ---------------------------------------------------
    async def refresh_all_usage(self, max_age: float = USAGE_TTL) -> None:
        await asyncio.gather(*(probe_usage(self.ctrl, a, max_age=max_age)
                               for a in self.pool.values()))

    def allowed_accounts(self):
        now = time.time()
        out = []
        for a in self.pool.values():
            if a.state == "allowed":
                out.append(a)
            elif a.state == "walled" and a.walled_until and now >= a.walled_until:
                a.state = "unknown"   # window reset; eligible for re-probe
        return out

    async def pick_account(self, thread_key: str) -> Optional[Account]:
        # affinity: keep a chat on its account while that account is still allowed
        cur = self.routes.get(thread_key)
        if cur and cur in self.pool:
            a = self.pool[cur]
            await probe_usage(self.ctrl, a, max_age=ROUTE_USAGE_TTL)
            if a.state == "allowed":
                await self.refresh_all_usage(max_age=ROUTE_USAGE_TTL)
                cands = self.allowed_accounts()
                if not should_spill_affinity(a, cands, SPILLOVER_HEADROOM_PCT):
                    return a
                log("SPILL %s headroom=%d%% below %d%% -> reroute" % (
                    a.email, a.headroom(), clamp_pct(SPILLOVER_HEADROOM_PCT)))
                self.routes.pop(thread_key, None)
        # otherwise (new chat, affinity account walled, or low-headroom spillover)
        # pick the freshest high-headroom account. This switch still lands between
        # turns because no upstream request has been opened yet.
        await self.refresh_all_usage(max_age=ROUTE_USAGE_TTL)
        cands = self.allowed_accounts()
        if not cands:
            return None
        cands.sort(key=lambda a: a.headroom(), reverse=True)
        # spread: among the top-headroom accounts, round-robin
        top = [a for a in cands if a.headroom() >= cands[0].headroom() - 10] or cands
        a = top[self.rr % len(top)]
        self.rr += 1
        self.routes.remember(thread_key, a.key)
        return a

    # --- request handling ----------------------------------------------------
    def thread_key(self, body: bytes, request: web.Request) -> str:
        with contextlib.suppress(Exception):
            obj = json.loads(body)
            for k in ("prompt_cache_key", "conversation_id", "session_id"):
                if obj.get(k):
                    return str(obj[k])
        # fall back to the client connection (each codex process = one socket peer)
        peer = request.transport.get_extra_info("peername") if request.transport else None
        return "conn:%s" % (peer,)

    async def handle(self, request: web.Request) -> web.StreamResponse:
        path = request.rel_url.raw_path
        # Codex routes its own token refresh here (CODEX_REFRESH_TOKEN_URL_OVERRIDE):
        if path.endswith("/oauth/token"):
            return await self.handle_refresh(request)
        # WebSocket upgrade: decline so codex falls back to plain HTTP.
        if request.headers.get("Upgrade", "").lower() == "websocket":
            return web.Response(status=426, text="websocket not proxied; use http")

        body = await request.read()
        tkey = self.thread_key(body, request)

        attempted = set()
        for attempt in range(len(self.pool) + 1):
            acct = await self.pick_account(tkey)
            if acct is None:
                return web.json_response(
                    {"error": {"message": "codexpool: all accounts are out of usage "
                               "right now (every account walled)."}}, status=429)
            if acct.key in attempted:
                # already tried everyone allowed; give up to avoid a loop
                return web.json_response(
                    {"error": {"message": "codexpool: no account could serve this turn."}},
                    status=429)
            attempted.add(acct.key)
            resp = await self.forward(request, path, body, acct, tkey)
            if resp is not None:
                return resp
            # forward() returned None => account walled; reassign and retry
            self.routes.pop(tkey, None)
        return web.json_response(
            {"error": {"message": "codexpool: exhausted accounts."}}, status=429)

    async def forward(self, request, path, body, acct, tkey):
        """Forward to upstream on `acct`. Returns a response, or None to signal a
        quota wall (caller should reassign to another account and retry)."""
        url = BACKEND_ORIGIN + path
        if request.rel_url.raw_query_string:
            url += "?" + request.rel_url.raw_query_string
        out_headers = {k: v for k, v in request.headers.items()
                       if k.lower() not in HOP_BY_HOP}
        # one 401-refresh retry on this same account
        for tok_try in range(2):
            out_headers["Authorization"] = "Bearer " + acct.access_token
            out_headers["ChatGPT-Account-Id"] = acct.account_id
            try:
                up = await self.fwd.request(
                    request.method, url, headers=out_headers,
                    data=body if body else None, allow_redirects=False,
                    timeout=aiohttp.ClientTimeout(total=None, sock_connect=30))
            except Exception as e:
                log("upstream error %s on %s: %s" % (path, acct.email, e))
                return web.Response(status=502, text="codexpool upstream error")
            if up.status == 401 and tok_try == 0:
                up.release()
                if await refresh_account(self.ctrl, acct):
                    continue
                if acct.state != "needs_reauth":
                    log("forward %s got 401 but refresh did not confirm reauth" %
                        acct.email)
                return None  # try another account
            break

        # HTTP 429 is only a wall after the payload confirms it is quota-related.
        if up.status == 429:
            text = await up.text()
            code, message = extract_error_from_text(text)
            up.release()
            if is_quota_signal(up.status, code, message, text):
                mark_account_walled(acct, path, code or message)
                return None
            return web.Response(status=up.status, body=text.encode(),
                                headers={k: v for k, v in up.headers.items()
                                         if k.lower() not in
                                         ("transfer-encoding", "content-length", "connection")})

        prefix = bytearray()
        prefix_iter = None
        if up.status == 200 and up.content_type == "text/event-stream":
            prefix_iter = up.content.iter_any()
            started = time.monotonic()
            while len(prefix) < SSE_PREFIX_MAX_BYTES and (
                    time.monotonic() - started) < SSE_PREFIX_MAX_SECONDS:
                try:
                    chunk = await prefix_iter.__anext__()
                except StopAsyncIteration:
                    break
                prefix.extend(chunk)
                reason, output_started = scan_sse_prefix(bytes(prefix))
                if reason:
                    up.release()
                    mark_account_walled(acct, path, reason)
                    return None
                # Once real output has started upstream, rerouting is no longer safe
                # even if a later event in the same stream eventually walls.
                if output_started:
                    break

        # stream the response straight back, unbuffered (SSE-safe)
        resp = web.StreamResponse(status=up.status)
        for k, v in up.headers.items():
            if k.lower() in ("transfer-encoding", "content-length", "connection"):
                continue
            resp.headers[k] = v
        await resp.prepare(request)
        log("%s %s -> %s [%d]" % (request.method, path, acct.email, up.status))
        # Keep watching the live stream for a quota/limit error event that
        # arrives AFTER output started (ChatGPT's 5h wall on a 200 SSE). We
        # can't reroute this turn, but flagging the account walled here breaks
        # the sticky affinity so the next turn fails over to a fresh account.
        is_sse = up.status == 200 and up.content_type == "text/event-stream"
        midstream_wall = None
        scan_tail = bytearray()
        try:
            if prefix:
                await resp.write(bytes(prefix))
            source = prefix_iter if prefix_iter is not None else up.content.iter_any()
            async for chunk in source:
                await resp.write(chunk)
                if is_sse and midstream_wall is None and (
                        b"error" in chunk or b"limit" in chunk
                        or b"quota" in chunk or b"rate" in chunk):
                    scan_tail.extend(chunk)
                    if len(scan_tail) > SSE_PREFIX_MAX_BYTES:
                        del scan_tail[:len(scan_tail) - SSE_PREFIX_MAX_BYTES]
                    with contextlib.suppress(Exception):
                        midstream_wall = scan_sse_for_quota(bytes(scan_tail))
        except Exception as e:
            log("stream interrupted %s: %s" % (path, e))
        finally:
            up.release()
        # Final sweep: the wall event is often the last block before the stream
        # closes, which the incremental scan may not have flushed.
        if is_sse and midstream_wall is None and scan_tail:
            with contextlib.suppress(Exception):
                midstream_wall = scan_sse_for_quota(bytes(scan_tail) + b"\n\n")
        if midstream_wall:
            mark_account_walled(acct, path, midstream_wall)
            self.routes.pop(tkey, None)
        with contextlib.suppress(Exception):
            await resp.write_eof()
        return resp

    async def handle_refresh(self, request: web.Request):
        """Serve codex's own token refresh centrally so codex never races the RT."""
        body = await request.read()
        body_data = parse_oauth_refresh_body(body, request.content_type)
        rt = body_data.get("refresh_token")
        wants_pool_token = wants_pool_managed_token(request, body_data)
        acct = None
        if rt and not wants_pool_token:
            for a in self.pool.values():
                if a.refresh_token == rt:
                    acct = a
                    break
        if acct is None and wants_pool_token:
            peer = request.transport.get_extra_info("peername") if request.transport else None
            acct = await self.pick_account("oauth-token:%s" % (peer,))
        if acct is None:
            # unknown RT: forward verbatim (don't break codex), but this is rare.
            async with self.ctrl.post(REFRESH_URL, data=body,
                                      headers={"Content-Type": request.headers.get(
                                          "Content-Type", "application/json")}) as r:
                return web.Response(status=r.status, body=await r.read(),
                                    content_type=r.content_type)
        if not token_valid_for(acct.access_token):
            refreshed = await refresh_account(self.ctrl, acct)
            if not refreshed:
                peer = request.transport.get_extra_info("peername") if request.transport else None
                fallback = await self.pick_account("oauth-token-fallback:%s" % (peer,))
                if fallback and fallback.key != acct.key:
                    acct = fallback
                    if not token_valid_for(acct.access_token):
                        refreshed = await refresh_account(self.ctrl, acct)
                if not token_valid_for(acct.access_token):
                    return web.json_response(
                        {"error": "codexpool_no_refreshable_accounts"},
                        status=401,
                    )
        refresh_out = CXP_MANAGED_REFRESH_TOKEN if wants_pool_token else acct.refresh_token
        return web.json_response(oauth_response_for_account(acct, refresh_token=refresh_out))


async def run_proxy() -> None:
    ensure_dirs()
    # --- HARD SINGLETON: exactly one proxy may ever manage the token pool ------
    # Two proxies sharing the pool double-spend rotating refresh tokens and
    # permanently burn accounts (forcing a browser re-login). The flock below is
    # a secondary guard only: a reinstall recreates ~/.codexpool and orphans the
    # lock inode, so flock alone is NOT reliable. The authoritative check is a
    # live-process scan (find_known_proxy_pids), which cannot be defeated by an
    # unlinked lock file. If any other cxp proxy is alive, we refuse to start.
    proxy_lock = open(PROXY_LOCK, "w")
    with contextlib.suppress(Exception):
        fcntl.flock(proxy_lock.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
    others = [p for p in find_known_proxy_pids() if pid_alive(p)]
    if others:
        msg = "another cxp proxy is already running (pid %s)" % \
              ", ".join(str(p) for p in others)
        log("singleton: refusing to start; %s" % msg)
        print("cxp: %s; not starting a second instance." % msg, file=sys.stderr)
        with contextlib.suppress(Exception):
            fcntl.flock(proxy_lock.fileno(), fcntl.LOCK_UN)
        proxy_lock.close()
        return
    import_accounts(verbose=False)
    proxy = Proxy()
    if not proxy.pool:
        print("cxp: no accounts in pool; run `cxp import` after `codex login`.",
              file=sys.stderr)
        sys.exit(1)
    proxy.ctrl = aiohttp.ClientSession(auto_decompress=True)
    proxy.fwd = aiohttp.ClientSession(auto_decompress=False)
    app = web.Application(client_max_size=1024 ** 3)
    app.router.add_route("*", "/{tail:.*}", proxy.handle)
    runner = web.AppRunner(app)
    port = None
    await runner.setup()
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    # STABLE PORT. Existing codex chats bake the proxy URL in at launch, so a proxy
    # restart on a fresh ephemeral port strands every live chat ("stream
    # disconnected ... 127.0.0.1:<old>"). Bind a fixed port so restarts are
    # transparent to running chats. Fall back to ephemeral only if it is taken.
    preferred = env_int("CXP_PROXY_PORT", 51805)
    try:
        sock.bind(("127.0.0.1", preferred))
    except OSError:
        log("preferred port %d unavailable; falling back to ephemeral" % preferred)
        sock.bind(("127.0.0.1", 0))
    port = sock.getsockname()[1]
    sock.close()
    site = web.TCPSite(runner, "127.0.0.1", port)
    await site.start()
    atomic_write_json(PORT_FILE, {"port": port, "pid": os.getpid()})
    log("proxy up on 127.0.0.1:%d with %d accounts" % (port, len(proxy.pool)))
    print("cxp proxy listening on 127.0.0.1:%d (%d accounts)" % (port, len(proxy.pool)),
          file=sys.stderr)
    stop = asyncio.Event()
    loop = asyncio.get_event_loop()
    for s in (signal.SIGTERM, signal.SIGINT):
        with contextlib.suppress(NotImplementedError):
            loop.add_signal_handler(s, stop.set)
    try:
        await stop.wait()
    finally:
        await proxy.ctrl.close()
        await proxy.fwd.close()
        await runner.cleanup()
        with contextlib.suppress(Exception):
            if isinstance(port, int) and port_record_owned_by(port, os.getpid()):
                PORT_FILE.unlink()
        with contextlib.suppress(Exception):
            fcntl.flock(proxy_lock.fileno(), fcntl.LOCK_UN)
        proxy_lock.close()


