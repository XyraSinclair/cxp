        "refresh_token": refresh_token if refresh_token is not None else acct.refresh_token,
        "id_token": acct.id_token,
        "expires_in": token_expires_in(acct.access_token),
        "token_type": "Bearer",
    }


def atomic_write_json(path: pathlib.Path, obj: dict) -> None:
    tmp = path.with_suffix(path.suffix + ".tmp.%d" % os.getpid())
    with open(tmp, "w") as fh:
        json.dump(obj, fh)
        fh.flush()
        os.fsync(fh.fileno())
    os.chmod(tmp, 0o600)
    os.replace(tmp, path)


def atomic_write_bytes(path: pathlib.Path, data: bytes, mode: int = 0o600) -> None:
    tmp = path.with_suffix(path.suffix + ".tmp.%d" % os.getpid())
    with open(tmp, "wb") as fh:
        fh.write(data)
        fh.flush()
        os.fsync(fh.fileno())
    os.chmod(tmp, mode)
    os.replace(tmp, path)


def next_available_path(path: pathlib.Path) -> pathlib.Path:
    stamp = time.strftime("%Y%m%dT%H%M%SZ", time.gmtime())
    for n in range(1000):
        suffix = ".bak.%s" % stamp if n == 0 else ".bak.%s.%d" % (stamp, n)
        candidate = path.with_name(path.name + suffix)
        if not candidate.exists():
            return candidate
    return path.with_name(path.name + ".bak.%s.%d" % (stamp, os.getpid()))


def move_existing_aside(path: pathlib.Path) -> Optional[pathlib.Path]:
    if not path.exists():
        return None
    dst = next_available_path(path)
    os.replace(path, dst)
    return dst


def parse_last_refresh(doc: dict) -> Optional[float]:
    stamp = doc.get("last_refresh")
    if not stamp:
        return None
    with contextlib.suppress(Exception):
        return float(calendar.timegm(time.strptime(stamp, "%Y-%m-%dT%H:%M:%SZ")))
    return None


def is_fresher_doc(candidate_doc: dict, candidate_path: pathlib.Path,
                   current_doc: dict, current_path: pathlib.Path) -> bool:
    cand_refresh = parse_last_refresh(candidate_doc)
    cur_refresh = parse_last_refresh(current_doc)
    if cand_refresh is not None and cur_refresh is not None and cand_refresh != cur_refresh:
        return cand_refresh > cur_refresh
    return candidate_path.stat().st_mtime >= current_path.stat().st_mtime


def extract_error_code_message(obj: dict) -> Tuple[Optional[str], Optional[str]]:
    code = None
    message = None
    err = obj.get("error")
    if isinstance(err, dict):
        code = err.get("code")
        message = err.get("message")
    resp = obj.get("response")
    if isinstance(resp, dict):
        rerr = resp.get("error")
        if isinstance(rerr, dict):
            code = code or rerr.get("code")
            message = message or rerr.get("message")
    code = code or obj.get("code")
    message = message or obj.get("message")
    return ((str(code) if code is not None else None),
            (str(message) if message is not None else None))


def is_quota_signal(status: Optional[int], code: Optional[str],
                    message: Optional[str], body_text: Optional[str]) -> bool:
    code_l = (code or "").strip().lower()
    hay = " ".join(x for x in (code or "", message or "", body_text or ""))
    hay = hay.strip().lower()
    if code_l in {
        "insufficient_quota",
        "usage_limit_reached",
        "rate_limit_exceeded",
        "quota_exceeded",
        "limit_reached",
    }:
        return True
    if any(tag in code_l for tag in ("quota", "usage_limit", "rate_limit", "limit_reached")):
        return True
    phrases = (
        "insufficient quota",
        "current quota",
        "quota exceeded",
        "usage limit",
        "usage_limit",
        "rate limit exceeded",
        "rate_limit_exceeded",
        "limit reached",
        "usage has reached",
    )
    if any(p in hay for p in phrases):
        return True
    return False


def iter_sse_json_events(buf: bytes):
    text = buf.decode("utf-8", "ignore").replace("\r\n", "\n")
    for block in text.split("\n\n")[:-1]:
        parts = []
        for line in block.split("\n"):
            if line.startswith("data:"):
                parts.append(line[5:].lstrip())
        if not parts:
            continue
        payload = "\n".join(parts).strip()
        if not payload or payload == "[DONE]":
            continue
        with contextlib.suppress(Exception):
            obj = json.loads(payload)
            if isinstance(obj, dict):
                yield obj


def sse_event_starts_output(event_type: str) -> bool:
    return (
        event_type.startswith("response.output_text.")
        or event_type.startswith("response.output_item.")
        or event_type.startswith("response.content_part.")
    )


def scan_sse_prefix(buf: bytes) -> Tuple[Optional[str], bool]:
    for obj in iter_sse_json_events(buf):
        ev_type = str(obj.get("type") or "")
        if sse_event_starts_output(ev_type):
            return None, True
        code, message = extract_error_code_message(obj)
        if ev_type in QUOTA_ERROR_TYPES or code or message:
            if is_quota_signal(200, code, message, json.dumps(obj, separators=(",", ":"))):
                return code or message or ev_type or "quota", False
    return None, False


def classify_sse_prefix(buf: bytes) -> Optional[str]:
    reason, _ = scan_sse_prefix(buf)
    return reason


def scan_sse_for_quota(buf: bytes) -> Optional[str]:
    """Scan an SSE buffer for a quota/limit error event ANYWHERE in it.

    Unlike scan_sse_prefix(), this does not bail at the first output event.
    ChatGPT delivers the 5h-window wall as an SSE error event *after* output
    has started, on a 200 response (never an HTTP 429), so the prefix scan
    misses it. We use this on the live relay to flag the account walled for
    the NEXT turn even though the current turn can no longer be rerouted.
    """
    for obj in iter_sse_json_events(buf):
        ev_type = str(obj.get("type") or "")
        code, message = extract_error_code_message(obj)
        if ev_type in QUOTA_ERROR_TYPES or code or message:
            if is_quota_signal(200, code, message,
                               json.dumps(obj, separators=(",", ":"))):
                return code or message or ev_type or "quota"
    return None


def extract_error_from_text(text: str) -> Tuple[Optional[str], Optional[str]]:
    with contextlib.suppress(Exception):
        obj = json.loads(text)
        if isinstance(obj, dict):
            return extract_error_code_message(obj)
    return None, None


def mark_account_walled(acct, path: str, reason: Optional[str]) -> None:
    acct.state = "walled"
    acct.usage_at = time.time()
    acct.walled_until = time.time() + 300
    acct.persist()
    why = (reason or "quota")[:80].replace("\n", " ")
    log("WALL %s on %s -> reroute (%s)" % (path, acct.email, why))


def clamp_pct(value: int) -> int:
    return max(0, min(100, value))


def utc_now() -> str:
    return time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())


def optional_int(value) -> Optional[int]:
    if value is None:
        return None
    with contextlib.suppress(Exception):
        return int(value)
    return None


def optional_float(value, default: float = 0.0) -> float:
    with contextlib.suppress(Exception):
        return float(value)
    return default


def mark_account_needs_reauth(acct, cooldown_seconds: float = 3600.0) -> None:
    acct.state = "needs_reauth"
    acct.usage_at = time.time()
    acct.reauth_cooldown_until = max(
        acct.reauth_cooldown_until,
        time.time() + cooldown_seconds,
    )
    acct.persist()


def should_spill_affinity(acct, candidates, threshold_pct: int) -> bool:
    """Return true when a still-allowed sticky route should move to a roomier account."""
    threshold_pct = clamp_pct(threshold_pct)
    if acct.state != "allowed":
        return True
    if acct.headroom() >= threshold_pct:
        return False
    return any(
        c.key != acct.key and c.state == "allowed" and c.headroom() > acct.headroom()
        for c in candidates
    )


class RouteLRU(collections.OrderedDict):
    def __init__(self, cap: int = ROUTES_MAX) -> None:
        super().__init__()
        self.cap = cap

    def get(self, key, default=None):
        if key not in self:
            return default
        value = super().__getitem__(key)
        self.move_to_end(key)
        return value

    def remember(self, key: str, value: str) -> None:
        super().__setitem__(key, value)
        self.move_to_end(key)
        while len(self) > self.cap:
            self.popitem(last=False)


# ============================================================================
#  Account store — one credential file per account, owned by the proxy.
# ============================================================================
class Account:
    def __init__(self, key: str, doc: dict):
        self.key = key
        tok = doc.get("tokens") or {}
        self.account_id: str = tok.get("account_id") or ""
        self.access_token: str = tok.get("access_token") or ""
        self.refresh_token: str = tok.get("refresh_token") or ""
        self.id_token: str = tok.get("id_token") or ""
        self.email: str = b64email(self.id_token) or "?"
        self.last_refresh: str = str(doc.get("last_refresh") or utc_now())
        meta = doc.get("cxp") or {}
        state = str(meta.get("state") or "unknown")
        # live state
        self.usage_5h: Optional[int] = optional_int(meta.get("usage_5h"))
        self.usage_week: Optional[int] = optional_int(meta.get("usage_week"))
        self.state: str = state if state in ACCOUNT_STATES else "unknown"
        self.usage_at: float = optional_float(meta.get("usage_at"))
        self.walled_until: float = optional_float(meta.get("walled_until"))
        # don't re-spam refresh on a dead RT
        self.reauth_cooldown_until: float = optional_float(
            meta.get("reauth_cooldown_until"))
        self.lock = None
        self.lock_loop = None

    def async_lock(self):
        loop = asyncio.get_running_loop()
        if self.lock is None or self.lock_loop is not loop:
            self.lock = asyncio.Lock()
            self.lock_loop = loop
        return self.lock

    def to_doc(self) -> dict:
        return {
            "auth_mode": "chatgpt",
            "tokens": {
                "account_id": self.account_id,
                "access_token": self.access_token,
                "refresh_token": self.refresh_token,
                "id_token": self.id_token,
            },
            "last_refresh": self.last_refresh,
            "cxp": {
                "state": self.state,
                "usage_5h": self.usage_5h,
                "usage_week": self.usage_week,
                "usage_at": self.usage_at,
                "walled_until": self.walled_until,
                "reauth_cooldown_until": self.reauth_cooldown_until,
            },
        }

    def to_auth_doc(self) -> dict:
        doc = self.to_doc()
        doc.pop("cxp", None)
        return doc

    def persist(self) -> None:
        atomic_write_json(ACCTS / (self.key + ".json"), self.to_doc())

    def headroom(self) -> int:
        u = max(self.usage_5h or 0, self.usage_week or 0)
        return max(0, 100 - u)


def import_accounts(verbose: bool = True) -> int:
    """Seed ~/.codexpool/accounts from ~/.codex/accounts (read-only source)."""
    ensure_dirs()
    n = 0
    for f in sorted(CODEX_ACCTS.glob("*.auth.json")):
        key = f.name[: -len(".auth.json")]
        dst = ACCTS / (key + ".json")
        if dst.exists():
            continue  # never clobber a pool credential we may have refreshed
        try:
            doc = json.loads(f.read_text())
        except Exception as e:
            if verbose:
                print("skip %s: %s" % (f.name, e))
            continue
        Account(key, doc).persist()
        n += 1
        if verbose:
            print("imported %s" % key)
    return n


def import_active_auth(verbose: bool = True) -> int:
    """Seed the pool from active ~/.codex/auth.json when it is a new account."""
    ensure_dirs()
    if not CODEX_AUTH.exists():
        return 0
    try:
        doc = json.loads(CODEX_AUTH.read_text())
    except Exception as e:
        if verbose:
            print("skip active auth: %s" % e)
        return 0
    tok = doc.get("tokens") or {}
    if not tok.get("account_id") or not tok.get("refresh_token"):
        return 0
    key = account_key_from_doc(doc)
    dst = ACCTS / (key + ".json")
    if dst.exists():
        return 0
    Account(key, doc).persist()
    audit_auth_event("import_active_auth", account=account_hint(Account(key, doc)),
                     account_id=tok.get("account_id"), key=key)
    if verbose:
        print("imported active auth %s" % key)
    return 1


def iter_pool_docs():
    for f in sorted(ACCTS.glob("*.json")):
        if f.name.endswith(".tmp") or ".tmp." in f.name:
            continue
        key = f.name[: -len(".json")]
        with contextlib.suppress(Exception):
            yield key, f, json.loads(f.read_text())


def load_pool() -> Dict[str, Account]:
    pool: Dict[str, Account] = {}
    acct_ids: Dict[str, Tuple[str, dict, pathlib.Path]] = {}
    for key, f, doc in iter_pool_docs():
        acct = Account(key, doc)
        if acct.account_id:
            cur = acct_ids.get(acct.account_id)
            if cur:
                cur_key, cur_doc, cur_path = cur
                if is_fresher_doc(doc, f, cur_doc, cur_path):
                    log("dedup: dropped %s (dup of %s)" % (cur_key, acct.account_id))
                    pool.pop(cur_key, None)
                    acct_ids[acct.account_id] = (key, doc, f)
                else:
                    log("dedup: dropped %s (dup of %s)" % (key, acct.account_id))
                    continue
            else:
                acct_ids[acct.account_id] = (key, doc, f)
        pool[key] = acct
    return pool


# ============================================================================
#  Token + usage — the safety-critical core.
# ============================================================================
async def refresh_account(sess: aiohttp.ClientSession, acct: Account,
                          notify: bool = True) -> bool:
    """Refresh one account's token. Single-flight per account (asyncio lock) and
    cross-process safe (file lock), so a rotating refresh token is never raced."""
    async with acct.async_lock():
        # cross-process lock so multiple cxp processes can't double-spend the RT
        lockpath = LOCKS / (acct.key + ".lock")
        lf = open(lockpath, "w")
        try:
            await asyncio.get_event_loop().run_in_executor(
                None, fcntl.flock, lf.fileno(), fcntl.LOCK_EX
            )
            # re-read the freshest persisted token (a peer may have just rotated it)
            with contextlib.suppress(Exception):
                fresh = json.loads((ACCTS / (acct.key + ".json")).read_text())
                acct.refresh_token = fresh["tokens"]["refresh_token"]
            body = {"client_id": CLIENT_ID, "grant_type": "refresh_token",
                    "refresh_token": acct.refresh_token}
            try:
                async with sess.post(REFRESH_URL, json=body,
                                     headers={"Content-Type": "application/json"},
                                     timeout=aiohttp.ClientTimeout(total=30)) as r:
                    if r.status != 200:
                        txt = (await r.text())[:200]
                        log("refresh %s FAILED %d %s" % (acct.email, r.status, txt))
                        if r.status in (400, 401):
                            # dead/burned refresh token: stop hammering it until the
                            # user re-logs in (or an hour passes).
                            mark_account_needs_reauth(acct)
                            audit_auth_event("refresh_needs_reauth",
                                             account=account_hint(acct),
                                             account_id=acct.account_id,
                                             status=r.status)
                            if notify:
                                notify_reauth_needed([acct])
                        return False
                    data = await r.json()
            except Exception as e:
                log("refresh %s error %s" % (acct.email, e))
                return False
            acct.access_token = data.get("access_token") or acct.access_token
            if data.get("refresh_token"):
                acct.refresh_token = data["refresh_token"]   # rotate
            if data.get("id_token"):
                acct.id_token = data["id_token"]
            acct.last_refresh = utc_now()
            acct.persist()   # persist rotated RT BEFORE use (atomic)
            log("refresh %s OK" % acct.email)
            return True
        finally:
            with contextlib.suppress(Exception):
                fcntl.flock(lf.fileno(), fcntl.LOCK_UN)
            lf.close()


async def probe_usage(sess: aiohttp.ClientSession, acct: Account,
                      allow_refresh: bool = True,
                      max_age: float = USAGE_TTL,
                      notify: bool = True) -> None:
    """Refresh acct.state/usage from live wham/usage."""
    if acct.state == "walled" and acct.walled_until and time.time() >= acct.walled_until:
        acct.state = "unknown"
        acct.persist()
    if max_age > 0 and time.time() - acct.usage_at < max_age and acct.state != "unknown":
        return
    # burned/dead account: only cxp login should replace this credential.
    if acct.state == "needs_reauth":
        return
    headers = {"Authorization": "Bearer " + acct.access_token,
               "ChatGPT-Account-Id": acct.account_id,
               "Accept": "application/json", "User-Agent": "cxp/0.1"}
    try:
        async with sess.get(WHAM_USAGE_URL, headers=headers,
                            timeout=aiohttp.ClientTimeout(total=15)) as r:
            status = r.status
            data = await r.json() if r.content_type == "application/json" else {}
    except Exception as e:
        log("usage %s error %s" % (acct.email, e))
        return
    if status == 401:
        if allow_refresh and await refresh_account(sess, acct, notify=notify):
            return await probe_usage(sess, acct, allow_refresh=False, max_age=0,
                                     notify=notify)
        if acct.state != "needs_reauth":
            if allow_refresh:
                log("usage %s got 401 but refresh did not confirm reauth" % acct.email)
            else:
                mark_account_needs_reauth(acct)
        if acct.state == "needs_reauth":
            audit_auth_event("usage_probe_needs_reauth",
                             account=account_hint(acct),
                             account_id=acct.account_id,
                             status=status)
            if notify:
                notify_reauth_needed([acct])
        return
    rate = (data or {}).get("rate_limit") or {}
    p = rate.get("primary_window") or {}
    s = rate.get("secondary_window") or {}
    acct.usage_5h = p.get("used_percent")
    acct.usage_week = s.get("used_percent")
    acct.usage_at = time.time()
    if rate.get("allowed"):
        acct.state = "allowed"
        acct.walled_until = 0.0
    elif rate.get("limit_reached"):
        acct.state = "walled"
        # remember the soonest reset so we re-probe after it
        resets = [w.get("reset_at") for w in (p, s) if w.get("used_percent") == 100]
        acct.walled_until = min([x for x in resets if x] or [time.time() + 300])
    else:
        acct.state = "unknown"
    acct.persist()


