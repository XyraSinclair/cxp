def ensure_dirs() -> None:
    for d in (BASE, ACCTS, LOCKS, PLACEHOLDER_HOME):
        d.mkdir(parents=True, exist_ok=True)
        with contextlib.suppress(Exception):
            os.chmod(d, 0o700)


def audit_auth_event(event: str, **fields) -> None:
    """Append a token-free auth audit event for login/reauth debugging."""
    BASE.mkdir(parents=True, exist_ok=True)
    clean = {}
    for k, v in fields.items():
        if "token" in k.lower():
            continue
        if v is None or isinstance(v, (str, int, float, bool)):
            clean[k] = v
        else:
            clean[k] = str(v)
    row = {
        "ts": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
        "event": event,
        **clean,
    }
    try:
        with open(AUTH_EVENTS, "a") as fh:
            fh.write(json.dumps(row, sort_keys=True) + "\n")
        with contextlib.suppress(Exception):
            os.chmod(AUTH_EVENTS, 0o600)
    except Exception:
        pass


def b64email(id_token: str) -> Optional[str]:
    try:
        mid = id_token.split(".")[1]
        mid += "=" * (-len(mid) % 4)
        return json.loads(base64.urlsafe_b64decode(mid)).get("email")
    except Exception:
        return None


def jwt_payload(token: str) -> Optional[dict]:
    try:
        mid = token.split(".")[1]
        mid += "=" * (-len(mid) % 4)
        payload = json.loads(base64.urlsafe_b64decode(mid))
        return payload if isinstance(payload, dict) else None
    except Exception:
        return None


def token_expires_in(access_token: str, default: int = 3000) -> int:
    exp = (jwt_payload(access_token) or {}).get("exp")
    if isinstance(exp, (int, float)):
        return max(0, int(exp - time.time()))
    return default


def token_valid_for(access_token: str, min_seconds: int = 60) -> bool:
    if not access_token:
        return False
    payload = jwt_payload(access_token)
    exp = (payload or {}).get("exp")
    if isinstance(exp, (int, float)):
        return exp - time.time() > min_seconds
    return True


def parse_oauth_refresh_body(body: bytes, content_type: str = "") -> dict:
    text = body.decode("utf-8", "ignore")
    ctype = (content_type or "").lower()

    def parse_json():
        with contextlib.suppress(Exception):
            obj = json.loads(text)
            if isinstance(obj, dict):
                return obj
        return None

    def parse_form():
        with contextlib.suppress(Exception):
            data = urllib.parse.parse_qs(text, keep_blank_values=True)
            return {k: v[-1] if v else "" for k, v in data.items()}
        return None

    if "json" in ctype:
        return parse_json() or parse_form() or {}
    if "x-www-form-urlencoded" in ctype:
        return parse_form() or parse_json() or {}
    return parse_json() or parse_form() or {}


def wants_pool_managed_token(request: web.Request, body_data: dict) -> bool:
    client = request.headers.get("X-CXP-Client", "").strip().lower()
    if client in {"omp", "codexpool"}:
        return True
    flag = str(body_data.get("cxp_pool_token") or "").strip().lower()
    return flag in {"1", "true", "yes", "omp"}


