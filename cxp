#  Launcher + status (sync helpers)
# ============================================================================
def read_port_record() -> Optional[dict]:
    try:
        raw = PORT_FILE.read_text().strip()
    except Exception:
        return None
    if not raw:
        return None
    with contextlib.suppress(Exception):
        obj = json.loads(raw)
        if isinstance(obj, dict):
            return obj
    with contextlib.suppress(Exception):
        return {"port": int(raw)}
    return None


def find_pid_for_port(port: int) -> Optional[int]:
    import subprocess
    with contextlib.suppress(Exception):
        cp = subprocess.run(
            ["lsof", "-tiTCP:%d" % port, "-sTCP:LISTEN"],
            check=False, capture_output=True, text=True,
        )
        for line in cp.stdout.splitlines():
            line = line.strip()
            if line.isdigit():
                return int(line)
    return None


def known_proxy_script_paths() -> set:
    paths = {str(AGENT_PROGRAM)}
    with contextlib.suppress(Exception):
        paths.add(os.path.realpath(__file__))
    return {os.path.realpath(p) for p in paths}


def is_known_cxp_proxy_command(command: str) -> bool:
    with contextlib.suppress(Exception):
        parts = shlex.split(command)
        targets = known_proxy_script_paths()
        for idx, part in enumerate(parts[:-1]):
            if parts[idx + 1] != "proxy":
                continue
            real = os.path.realpath(part)
            if real in targets:
                return True
            if pathlib.Path(part).name in {"cxp", "cxp-agent"}:
                if "/.codexpool/" in part or "/codexpool/" in part:
                    return True
    return False


def process_command(pid: int) -> str:
    import subprocess
    with contextlib.suppress(Exception):
        cp = subprocess.run(
            ["ps", "-p", str(pid), "-o", "command="],
            check=False, capture_output=True, text=True,
        )
        return cp.stdout.strip()
    return ""


def process_is_known_cxp_proxy(pid: int) -> bool:
    return is_known_cxp_proxy_command(process_command(pid))


def find_known_proxy_pids() -> List[int]:
    import subprocess
    pids: List[int] = []
    with contextlib.suppress(Exception):
        cp = subprocess.run(
            ["ps", "-axo", "pid=,command="],
            check=False, capture_output=True, text=True,
        )
        for line in cp.stdout.splitlines():
            text = line.strip()
            pid_s, _, command = text.partition(" ")
            if not pid_s.isdigit():
                continue
            pid = int(pid_s)
            if pid != os.getpid() and is_known_cxp_proxy_command(command):
                pids.append(pid)
    return sorted(set(pids))


def pid_alive(pid: int) -> bool:
    with contextlib.suppress(OSError):
        os.kill(pid, 0)
        return True
    return False


def port_record_owned_by(port: int, pid: int) -> bool:
    rec = read_port_record() or {}
    return rec.get("port") == port and rec.get("pid") == pid


def proxy_alive() -> Optional[int]:
    rec = read_port_record()
    if not rec:
        return None
    port = rec.get("port")
    if not isinstance(port, int):
        return None
    pid = rec.get("pid")
    listener_pid = find_pid_for_port(port)
    if isinstance(pid, int):
        if not pid_alive(pid):
            return None
        if isinstance(listener_pid, int) and listener_pid != pid:
            return None
        if not process_is_known_cxp_proxy(pid):
            return None
    elif isinstance(listener_pid, int) and not process_is_known_cxp_proxy(listener_pid):
        return None
    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    s.settimeout(0.5)
    try:
        s.connect(("127.0.0.1", port))
        return port
    except Exception:
        return None
    finally:
        s.close()


def shell_cmd(*parts: str) -> str:
    return " ".join(shlex.quote(str(p)) for p in parts)


def osa_string(s: str) -> str:
    return '"' + s.replace("\\", "\\\\").replace('"', '\\"') + '"'


def account_hint(acct: Account) -> str:
    if acct.email and acct.email != "?":
        return acct.email
    return acct.key


def ownership_conflicts_for_pool(pool: Dict[str, Account]) -> dict:
    """Find places where vanilla Codex can still refresh pooled credentials."""
    pooled_keys = set(pool.keys())
    pooled_ids = {a.account_id for a in pool.values() if a.account_id}
    account_files = []
    for key in sorted(pooled_keys):
        if (CODEX_ACCTS / (key + ".auth.json")).exists():
            account_files.append(key)

    active_auth = None
    with contextlib.suppress(Exception):
        doc = json.loads(CODEX_AUTH.read_text())
        tok = doc.get("tokens") or {}
        account_id = tok.get("account_id")
        if account_id and account_id in pooled_ids:
            active_auth = {
                "account_id": account_id,
                "email": b64email(tok.get("id_token", "")) or "?",
            }
    return {"account_files": account_files, "active_auth": active_auth}


def has_ownership_conflicts(conflicts: dict) -> bool:
    return bool(conflicts.get("account_files") or conflicts.get("active_auth"))


def autoheal_ownership(pool: Dict[str, Account], source: str) -> Tuple[Dict[str, Account], dict]:
    conflicts = ownership_conflicts_for_pool(pool)
    if has_ownership_conflicts(conflicts):
        print("autoheal: moving shared vanilla Codex credentials under cxp ownership.")
        audit_auth_event("%s_auto_quarantine" % source,
                         account_files=len(conflicts.get("account_files") or []),
                         active_auth=bool(conflicts.get("active_auth")))
        cmd_quarantine()
        pool = load_pool()
        conflicts = ownership_conflicts_for_pool(pool)
    return pool, conflicts


def status_fix_lines(pool: Dict[str, Account], port: Optional[int],
                     conflicts: dict, skipped_refresh: bool) -> List[str]:
    lines: List[str] = []
    needs = sorted(
        (a for a in pool.values() if a.state == "needs_reauth"),
        key=lambda a: account_hint(a),
    )
    unknown = sorted(
        (a for a in pool.values() if a.state == "unknown"),
        key=lambda a: account_hint(a),
    )
    walled = sorted(
        (a for a in pool.values() if a.state == "walled"),
        key=lambda a: account_hint(a),
    )

    if has_ownership_conflicts(conflicts):
        account_file_count = len(conflicts.get("account_files") or [])
        active = conflicts.get("active_auth")
        detail = "%d ~/.codex/accounts file(s)" % account_file_count
        if active:
            detail += " plus ~/.codex/auth.json"
        lines.append("auth ownership conflict: vanilla Codex can still refresh %s." % detail)
        lines.append("Run these before trusting any REAUTH row:")
        lines.append("  " + shell_cmd("cxp", "stop"))
        lines.append("  " + shell_cmd("cxp", "quarantine"))
        lines.append("  " + shell_cmd("cxp", "install-agent"))
        lines.append("  " + shell_cmd("cxp", "status"))
        if skipped_refresh:
            lines.append("Status did not refresh tokens while ownership is shared.")
        if needs:
            lines.append("If rows are still REAUTH after that, refresh only those accounts:")
            for acct in needs:
                lines.append("  " + shell_cmd("cxp", "login", account_hint(acct)))
            lines.append("  " + shell_cmd("cxp", "status"))
        return lines

    if needs:
        lines.append("login required for REAUTH rows:")
        for acct in needs:
            lines.append("  " + shell_cmd("cxp", "login", account_hint(acct)))
        lines.append("  " + shell_cmd("cxp", "status"))
    else:
        lines.append("login: no account currently needs `cxp login`.")

    if not port:
        lines.append("proxy is not running:")
        lines.append("  " + shell_cmd("cxp", "install-agent"))
        lines.append("  " + shell_cmd("cxp", "status"))
        lines.append("one-shot alternative:")
        lines.append("  " + shell_cmd("cxp", "restart"))

    if unknown:
        lines.append("unknown usage rows: restart the proxy, then inspect the proxy log if they stay unknown:")
        lines.append("  " + shell_cmd("cxp", "restart"))
        lines.append("  " + shell_cmd("tail", "-n", "80", str(LOG_FILE)))

    if walled:
        lines.append("walled rows are quota windows, not auth failures; cxp should route around them.")

    if not needs and port and not unknown:
        lines.append("fix: no immediate command needed.")
    return lines


def print_status_fixes(pool: Dict[str, Account], port: Optional[int],
                       conflicts: dict, skipped_refresh: bool) -> None:
    print("\nfix commands")
    print("-" * 63)
    for line in status_fix_lines(pool, port, conflicts, skipped_refresh):
        print(line)


def notify_process_alive(pid: Optional[int]) -> bool:
    return isinstance(pid, int) and pid_alive(pid)


def notify_reauth_needed(accounts) -> None:
    """Show a sticky macOS alert for accounts that need browser login."""
    accounts = [a for a in accounts if a.state == "needs_reauth"]
    if not accounts or sys.platform != "darwin":
        return
    ensure_dirs()
    keys = {a.key for a in accounts}
    names_by_key = {a.key: account_hint(a) for a in accounts}
    with contextlib.suppress(Exception):
        state = json.loads(NOTIFY_STATE.read_text())
        old_keys = {k for k in str(state.get("fingerprint") or "").split(",") if k}
        keys |= old_keys
        for name in state.get("accounts") or []:
            names_by_key.setdefault(str(name), str(name))
        age = time.time() - float(state.get("shown_ts") or 0)
        if state.get("fingerprint") == ",".join(sorted(keys)):
            return
        if age < NOTIFY_MIN_INTERVAL_SECONDS:
            state["fingerprint"] = ",".join(sorted(keys))
            state["accounts"] = sorted(names_by_key.values())
            atomic_write_json(NOTIFY_STATE, state)
            return
    fingerprint = ",".join(sorted(keys))
    names = ", ".join(sorted(names_by_key.values()))
    message = (
        "codexpool needs browser login for: %s. "
        "This dialog is one-shot for the current account set and will not open "
        "Terminal, browser tabs, or recursive repair commands."
    ) % names
    script = (
        "display dialog %s buttons {\"OK\"} default button \"OK\" "
        "with title \"codexpool login required\" with icon caution\n"
    ) % osa_string(message)
    try:
        import subprocess
        proc = subprocess.Popen(
            ["osascript", "-e", script],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
        )
        atomic_write_json(NOTIFY_STATE, {
            "fingerprint": fingerprint,
            "pid": proc.pid,
            "accounts": sorted(names_by_key.values()),
            "shown_at": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
            "shown_ts": time.time(),
        })
        audit_auth_event("reauth_notification_shown", accounts=names, pid=proc.pid)
    except Exception as e:
        audit_auth_event("reauth_notification_failed", accounts=names, error=str(e))


def agent_needs_install() -> bool:
    if not AGENT_PLIST.exists():
        return True
    if not AGENT_PROGRAM.exists():
        return True
    with contextlib.suppress(Exception):
        if pathlib.Path(os.path.realpath(__file__)).stat().st_mtime > AGENT_PROGRAM.stat().st_mtime:
            return True
    try:
        data = plistlib.loads(AGENT_PLIST.read_bytes())
    except Exception:
        return True
    expected = [str(AGENT_PROGRAM), "proxy"]
    # Accept either legacy KeepAlive=True or the crash-only dict form. Anything
    # truthy means supervision is present; only a missing/false value needs a
    # reinstall. (A strict == True check would reinstall on every launch and
    # bounce the proxy via cmd_stop, churning tokens.)
    keepalive = data.get("KeepAlive")
    keepalive_ok = keepalive is True or isinstance(keepalive, dict) and bool(keepalive)
    return (
        data.get("ProgramArguments") != expected
        or data.get("RunAtLoad") is not True
        or not keepalive_ok
    )


def ensure_proxy() -> int:
    port = proxy_alive()
    if port:
        return port
    # spawn detached
    import subprocess
    subprocess.Popen([sys.executable, os.path.realpath(__file__), "proxy"],
                     stdout=open(LOG_FILE, "a"), stderr=subprocess.STDOUT,
                     start_new_session=True)
    for _ in range(100):
        time.sleep(0.1)
        port = proxy_alive()
        if port:
            return port
    print("cxp: proxy failed to start; see %s" % LOG_FILE, file=sys.stderr)
    sys.exit(1)


def write_placeholder_auth() -> None:
    """Give the launched codex a CODEX_HOME with a valid-looking auth.json so it
    doesn't prompt login. The proxy overrides the bearer on every backend call and
    serves codex's own refreshes, so this token is only a 'don't prompt' placeholder."""
    pool = load_pool()
    if not pool:
        return
    auth = PLACEHOLDER_HOME / "auth.json"
    # Prefer the user's currently-active codex account (usually healthy & refreshable)
    # so codex starts cleanly; the proxy overrides the real bearer per request anyway.
    real = HOME / ".codex" / "auth.json"
    with contextlib.suppress(Exception):
        if real.exists():
            doc = json.loads(real.read_text())
            if (doc.get("tokens") or {}).get("access_token"):
                doc.pop("cxp", None)
                atomic_write_json(auth, doc)
                _copy_real_config()
                return
    acct = sorted(pool.values(), key=lambda a: a.key)[0]
    atomic_write_json(auth, acct.to_auth_doc())
    _copy_real_config()


def _copy_real_config() -> None:
    """Mirror the user's real ~/.codex/config.toml so models/settings are unchanged."""
    real_cfg = HOME / ".codex" / "config.toml"
    dst_cfg = PLACEHOLDER_HOME / "config.toml"
    with contextlib.suppress(Exception):
        if real_cfg.exists():
            dst_cfg.write_text(real_cfg.read_text())


def real_codex_path() -> str:
    """Absolute path to the REAL codex binary, skipping our own shim dir
    (~/.codexpool/bin). The transparent `codex` shim routes through cxp, and cxp
    re-execs codex; without skipping the shim dir that would recurse forever."""
    shim_dir = os.path.realpath(str(BASE / "bin"))
    for d in (os.environ.get("PATH") or "").split(os.pathsep):
        if not d:
            continue
        with contextlib.suppress(Exception):
            if os.path.realpath(d) == shim_dir:
                continue
        cand = os.path.join(d, "codex")
        if os.path.isfile(cand) and os.access(cand, os.X_OK):
            return cand
    for fb in (os.path.expanduser("~/.nvm/versions/node/v24.13.1/bin/codex"),):
        if os.path.isfile(fb):
            return fb
    return "codex"


def launch(codex_args, apply_preset: bool = True) -> None:
    ensure_dirs()
    import_accounts(verbose=False)
    import_active_auth(verbose=False)
    if CXP_AUTO_FIX:
        pool = load_pool()
        if pool:
            autoheal_ownership(pool, "launch")
        if agent_needs_install():
            print("autoheal: installing launchd supervision for the cxp proxy.")
            audit_auth_event("launch_auto_install_agent", plist=str(AGENT_PLIST))
            cmd_install_agent()
    port = ensure_proxy()
    write_placeholder_auth()
    # Route codex through the proxy via a CUSTOM provider with websockets DISABLED.
    # (Codex's responses WebSocket is hardcoded to wss://chatgpt.com and ignores
    # chatgpt_base_url, so it would bypass the proxy. requires_openai_auth=true makes
    # the custom provider use the ChatGPT tokens; the proxy injects the real bearer.)
    pbase = "http://127.0.0.1:%d/backend-api/codex" % port
    env = dict(os.environ)
    env["CODEX_HOME"] = str(PLACEHOLDER_HOME)
    env["CODEX_REFRESH_TOKEN_URL_OVERRIDE"] = "http://127.0.0.1:%d/oauth/token" % port
    env["NO_PROXY"] = "127.0.0.1,localhost,::1"
    env["no_proxy"] = env["NO_PROXY"]
    # Pool-routing essentials — ALWAYS injected so the single proxy is the only
    # token refresher (this is what makes accounts stop getting burned).
    provider = [
        "-c", "model_providers.codexpool.name=codexpool",
        "-c", "model_providers.codexpool.base_url=" + pbase,
        "-c", 'model_providers.codexpool.wire_api="responses"',
        "-c", "model_providers.codexpool.requires_openai_auth=true",
        "-c", "model_providers.codexpool.supports_websockets=false",
        "-c", "model_provider=codexpool",
    ]
    # Interactive cosmetics. Skipped in passthrough mode (the transparent shim)
    # so `codex exec --full-auto -m gpt-5.4 ...` keeps the caller's OWN flags.
    preset = [
        "--dangerously-bypass-approvals-and-sandbox",
        "-c", "model_reasoning_summary=detailed",
        "-c", "model_reasoning_effort=xhigh",
        "-m", "gpt-5.5",
    ] if apply_preset else []
    real = real_codex_path()
    argv = [real] + provider + preset + list(codex_args)
    os.execve(real, argv, env)


def account_key_from_doc(doc: dict) -> str:
    """Codex's stable account key: base64url(sub::account_id) from the id_token."""
    tok = doc.get("tokens") or {}
    sub = None
    with contextlib.suppress(Exception):
        mid = tok.get("id_token", "").split(".")[1]
        mid += "=" * (-len(mid) % 4)
        sub = json.loads(base64.urlsafe_b64decode(mid)).get("sub")
    raw = ("%s::%s" % (sub or "user", tok.get("account_id") or "")).encode()
    return base64.urlsafe_b64encode(raw).decode().rstrip("=")


def cmd_login(hint: Optional[str]) -> None:
    """Browser-OAuth an account into the pool (revives a burned/expired account).
    Runs `codex login` in a throwaway CODEX_HOME so nothing else is disturbed."""
    ensure_dirs()
    import shutil
    import subprocess
    tmp = BASE / "login-tmp"
    shutil.rmtree(tmp, ignore_errors=True)
    tmp.mkdir(parents=True)
    print("Opening a browser to sign in%s. Pick the account you want to add."
          % ((" for %s" % hint) if hint else ""))
    audit_auth_event("login_start", hint=hint or "")
    env = dict(os.environ)
    env["CODEX_HOME"] = str(tmp)
    env.pop("CODEX_REFRESH_TOKEN_URL_OVERRIDE", None)  # real login, no proxy override
    cp = subprocess.run([real_codex_path(), "login"], env=env)
    auth = tmp / "auth.json"
    if not auth.exists():
        print("login did not complete (no auth.json produced).")
        audit_auth_event("login_failed", hint=hint or "", returncode=cp.returncode,
                         reason="no_auth_json")
        shutil.rmtree(tmp, ignore_errors=True)
        return
    doc = json.loads(auth.read_text())
    key = account_key_from_doc(doc)
    Account(key, doc).persist()
    email = b64email((doc.get("tokens") or {}).get("id_token", "")) or "?"
    if hint and "@" in hint and email.lower() != hint.lower():
        print("warning: browser returned %s, not requested hint %s." % (email, hint))
        audit_auth_event("login_hint_mismatch", hint=hint, account=email, key=key)
    audit_auth_event("login_complete", hint=hint or "", account=email,
                     account_id=(doc.get("tokens") or {}).get("account_id"), key=key,
                     returncode=cp.returncode)
    shutil.rmtree(tmp, ignore_errors=True)
    print("Added/refreshed %s in the pool. Run `cxp status` to confirm." % email)


def status_auto_login_enabled() -> bool:
    return CXP_STATUS_AUTO_LOGIN and sys.stdin.isatty()


def status_probe_pool_quiet(pool: Dict[str, Account], allow_refresh: bool) -> None:
    async def go():
        async with aiohttp.ClientSession(auto_decompress=True) as s:
            await asyncio.gather(*(probe_usage(s, a, allow_refresh=allow_refresh,
                                               notify=False)
                                   for a in pool.values()))
    asyncio.run(go())


def cmd_status() -> None:
    ensure_dirs()
    import_accounts(verbose=False)
    import_active_auth(verbose=False)
    pool = load_pool()
    if not pool:
        if status_auto_login_enabled():
            print("autoheal: no pool accounts; starting login.")
            audit_auth_event("status_auto_login_start", reason="empty_pool")
            cmd_login(None)
            import_active_auth(verbose=False)
            pool = load_pool()
        if not pool:
            print("no accounts in pool.")
            print("\nfix commands")
            print("-" * 63)
            print(shell_cmd("cxp", "login"))
            print(shell_cmd("cxp", "status"))
            print("\nIf you already logged in with vanilla Codex instead:")
            print(shell_cmd("cxp", "import"))
            print(shell_cmd("cxp", "quarantine"))
            print(shell_cmd("cxp", "install-agent"))
            print(shell_cmd("cxp", "status"))
            return

    if CXP_STATUS_AUTO_FIX:
        pool, conflicts = autoheal_ownership(pool, "status")
    else:
        conflicts = ownership_conflicts_for_pool(pool)

    if CXP_STATUS_AUTO_FIX and agent_needs_install():
        print("autoheal: installing launchd supervision for the cxp proxy.")
        audit_auth_event("status_auto_install_agent", plist=str(AGENT_PLIST))
        cmd_install_agent()

    allow_status_refresh = not has_ownership_conflicts(conflicts)
    status_probe_pool_quiet(pool, allow_refresh=allow_status_refresh)

    needs = [a for a in pool.values() if a.state == "needs_reauth"]
    if needs:
        audit_auth_event("status_reauth_needed",
                         accounts=", ".join(account_hint(a) for a in needs),
                         count=len(needs))
        if status_auto_login_enabled():
            print("autoheal: starting browser login for %d account(s)." % len(needs))
            for acct in sorted(needs, key=account_hint):
                audit_auth_event("status_auto_login_start",
                                 account=account_hint(acct),
                                 account_id=acct.account_id)
                cmd_login(account_hint(acct))
            pool = load_pool()
            conflicts = ownership_conflicts_for_pool(pool)
            allow_status_refresh = not has_ownership_conflicts(conflicts)
            status_probe_pool_quiet(pool, allow_refresh=allow_status_refresh)
        else:
            notify_reauth_needed(needs)

    needs_after_login = [a for a in pool.values() if a.state == "needs_reauth"]
    if needs_after_login:
        notify_reauth_needed(needs_after_login)

    port = proxy_alive()
    print("codexpool — proxy: %s" % ("up on 127.0.0.1:%d" % port if port else "not running"))
    print("routing — spill below %d%% headroom; route usage ttl %.1fs" % (
        SPILLOVER_HEADROOM_PCT, ROUTE_USAGE_TTL))
    if has_ownership_conflicts(conflicts):
        print("auth owner — conflict; status probe used no-refresh mode")
    else:
        print("auth owner — ok; cxp is the only known refresher for pooled accounts")
    print("%-26s %-12s %5s %7s %8s" % ("ACCOUNT", "STATE", "5H", "WEEKLY", "HEADROOM"))
    print("-" * 63)
    for a in sorted(pool.values(), key=lambda a: a.email):
        five = "-" if a.usage_5h is None else "%d%%" % a.usage_5h
        week = "-" if a.usage_week is None else "%d%%" % a.usage_week
        headroom = "-" if a.usage_5h is None and a.usage_week is None else "%d%%" % a.headroom()
        tag = {"allowed": "OK", "walled": "WALLED",
               "needs_reauth": "REAUTH"}.get(a.state, a.state)
        print("%-26s %-12s %5s %7s %8s" % (a.email[:26], tag, five, week, headroom))
    usable = [a for a in pool.values() if a.state == "allowed"]
    print("\nusable now: %d / %d  %s" % (
        len(usable), len(pool), ", ".join(a.email for a in usable) or "(none)"))
    print_status_fixes(pool, port, conflicts, skipped_refresh=not allow_status_refresh)


def cmd_auth_log() -> None:
    if not AUTH_EVENTS.exists():
        print("no auth events yet: %s" % AUTH_EVENTS)
        return
    rows = collections.deque(maxlen=80)
    with open(AUTH_EVENTS) as fh:
        for line in fh:
            if line.strip():
                rows.append(line.rstrip("\n"))
    for row in rows:
        print(row)


def cmd_stop() -> None:
    rec = read_port_record() or {}
    port = rec.get("port")
    pid = rec.get("pid")
    targets: List[int] = []
    if isinstance(pid, int) and process_is_known_cxp_proxy(pid):
        targets.append(pid)
    elif isinstance(port, int):
        listener_pid = find_pid_for_port(port)
        if isinstance(listener_pid, int) and process_is_known_cxp_proxy(listener_pid):
            targets.append(listener_pid)
    targets.extend(find_known_proxy_pids())
    targets = sorted({p for p in targets if p != os.getpid()})
    if not targets:
        with contextlib.suppress(Exception):
            PORT_FILE.unlink()
        print("proxy not running.")
        return
    for target in targets:
        with contextlib.suppress(ProcessLookupError):
            os.kill(target, signal.SIGTERM)
    deadline = time.time() + 5
    while any(pid_alive(target) for target in targets) and time.time() < deadline:
        time.sleep(0.1)
    # Escalate to SIGKILL for anything that ignored SIGTERM. Convergence (e.g.
    # install-agent) MUST end with zero old proxies, or the new supervised proxy
    # will guard-refuse to start and crash-only KeepAlive won't revive it.
    stubborn = [target for target in targets if pid_alive(target)]
    if stubborn:
        for target in stubborn:
            with contextlib.suppress(ProcessLookupError):
                os.kill(target, signal.SIGKILL)
        kill_deadline = time.time() + 3
        while any(pid_alive(target) for target in stubborn) and time.time() < kill_deadline:
            time.sleep(0.1)
    with contextlib.suppress(Exception):
        PORT_FILE.unlink()
    alive = [target for target in targets if pid_alive(target)]
    if alive:
        print("WARNING: proxy pid(s) %s survived SIGTERM+SIGKILL; cleaned %s" %
              (", ".join(str(p) for p in alive), PORT_FILE))
    else:
        print("stopped proxy pid(s) %s." % ", ".join(str(p) for p in targets))


def cmd_restart() -> None:
    cmd_stop()
    port = ensure_proxy()
    print("restarted proxy on 127.0.0.1:%d." % port)


def cmd_quarantine() -> None:
    import shutil
    pooled_keys = set()
    pooled_ids = set()
    for key, _, doc in iter_pool_docs():
        pooled_keys.add(key)
        acct_id = ((doc.get("tokens") or {}).get("account_id") or "")
        if acct_id:
            pooled_ids.add(acct_id)
    moves = []
    for key in sorted(pooled_keys):
        src = CODEX_ACCTS / (key + ".auth.json")
        dst = CODEX_QUARANTINE / src.name
        if src.exists():
            moves.append((src, dst))
    auth_move = False
    active_id = None
    with contextlib.suppress(Exception):
        doc = json.loads(CODEX_AUTH.read_text())
        active_id = (doc.get("tokens") or {}).get("account_id")
        auth_move = bool(active_id and active_id in pooled_ids and CODEX_AUTH.exists())
    print("quarantine: %d pooled account file(s), active auth move=%s" % (
        len(moves), "yes" if auth_move else "no"))
    if not moves and not auth_move:
        print("nothing to move.")
        return
    CODEX_QUARANTINE.mkdir(parents=True, exist_ok=True)
    with contextlib.suppress(Exception):
        os.chmod(CODEX_QUARANTINE, 0o700)
    moved = []
    for src, dst in moves:
        aside = move_existing_aside(dst)
        if aside:
            print("move existing %s -> %s" % (dst, aside))
        print("move %s -> %s" % (src, dst))
        shutil.move(str(src), str(dst))
        moved.append((src, dst))
    if auth_move:
        aside = move_existing_aside(CODEX_AUTH_BAK)
        if aside:
            print("move existing %s -> %s" % (CODEX_AUTH_BAK, aside))
        print("move %s -> %s" % (CODEX_AUTH, CODEX_AUTH_BAK))
        shutil.move(str(CODEX_AUTH), str(CODEX_AUTH_BAK))
    elif CODEX_AUTH_BAK.exists() and not CODEX_AUTH.exists():
        print("active auth already quarantined at %s" % CODEX_AUTH_BAK)
    print("quarantine complete: moved %d account file(s)%s." % (
        len(moved), " and auth.json" if auth_move else ""))
    print("undo: run `cxp unquarantine`.")


def cmd_unquarantine() -> None:
    import shutil
    pooled_keys = {key for key, _, _ in iter_pool_docs()}
    restores = []
    if CODEX_QUARANTINE.exists():
        for src in sorted(CODEX_QUARANTINE.glob("*.auth.json")):
            key = src.name[: -len(".auth.json")]
            if key in pooled_keys:
                restores.append((src, CODEX_ACCTS / src.name))
    auth_restore = CODEX_AUTH_BAK.exists() and not CODEX_AUTH.exists()
    print("unquarantine: %d pooled account file(s), active auth restore=%s" % (
        len(restores), "yes" if auth_restore else "no"))
    if not restores and not auth_restore:
        print("nothing to restore.")
        return
    restored = []
    for src, dst in restores:
        if dst.exists():
            continue
        print("move %s -> %s" % (src, dst))
        shutil.move(str(src), str(dst))
        restored.append((src, dst))
    if auth_restore:
        print("move %s -> %s" % (CODEX_AUTH_BAK, CODEX_AUTH))
        shutil.move(str(CODEX_AUTH_BAK), str(CODEX_AUTH))
    print("unquarantine complete: restored %d account file(s)%s." % (
        len(restored), " and auth.json" if auth_restore else ""))


def cmd_install_agent() -> None:
    import subprocess
    ensure_dirs()
    AGENT_PLIST.parent.mkdir(parents=True, exist_ok=True)
    source = pathlib.Path(os.path.realpath(__file__))
    atomic_write_bytes(AGENT_PROGRAM, source.read_bytes(), mode=0o700)
    program = str(AGENT_PROGRAM)
    data = {
        "Label": AGENT_LABEL,
        "ProgramArguments": [program, "proxy"],
        "RunAtLoad": True,
        # Crash-only restart. With the hard singleton guard, a redundant launch
        # exits cleanly (0); plain KeepAlive=True would respawn it forever in a
        # busy-loop. SuccessfulExit:False restarts ONLY on a real crash.
        "KeepAlive": {"SuccessfulExit": False},
        "StandardOutPath": str(BASE / "agent.out.log"),
        "StandardErrorPath": str(BASE / "agent.err.log"),
    }
    atomic_write_bytes(AGENT_PLIST, plistlib.dumps(data), mode=0o644)
    subprocess.run(["launchctl", "unload", "-w", str(AGENT_PLIST)],
                   check=False, capture_output=True, text=True)
    cmd_stop()
    cp = subprocess.run(["launchctl", "load", "-w", str(AGENT_PLIST)],
                        check=False, capture_output=True, text=True)
    if cp.returncode != 0:
        print("launchctl load failed: %s" % ((cp.stderr or cp.stdout).strip() or cp.returncode))
        return
    print("installed %s at %s" % (AGENT_LABEL, AGENT_PLIST))
    print("program: %s proxy" % program)
    print("source: %s" % source)


def cmd_uninstall_agent() -> None:
    import subprocess
    if AGENT_PLIST.exists():
        cp = subprocess.run(["launchctl", "unload", "-w", str(AGENT_PLIST)],
                            check=False, capture_output=True, text=True)
        with contextlib.suppress(Exception):
            AGENT_PLIST.unlink()
        if cp.returncode == 0:
            print("uninstalled %s." % AGENT_LABEL)
        else:
            print("launchctl unload returned %d; removed %s." %
                  (cp.returncode, AGENT_PLIST))
        return
    print("%s is not installed." % AGENT_LABEL)


def main() -> None:
    args = sys.argv[1:]
    if args and args[0] == "proxy":
        asyncio.run(run_proxy())
    elif args and args[0] == "status":
        cmd_status()
    elif args and args[0] == "import":
        ensure_dirs()
        n = import_accounts()
        n += import_active_auth()
        print("imported %d new account(s); pool now has %d" % (n, len(load_pool())))
    elif args and args[0] == "auth-log":
        cmd_auth_log()
    elif args and args[0] == "login":
        cmd_login(args[1] if len(args) > 1 else None)
    elif args and args[0] == "quarantine":
        cmd_quarantine()
    elif args and args[0] == "unquarantine":
        cmd_unquarantine()
    elif args and args[0] == "stop":
        cmd_stop()
    elif args and args[0] == "restart":
        cmd_restart()
    elif args and args[0] == "install-agent":
        cmd_install_agent()
    elif args and args[0] == "uninstall-agent":
        cmd_uninstall_agent()
    elif args and args[0] == "__codex":
        # Transparent-shim entrypoint: launch codex through the pool with the
        # caller's args verbatim and NO interactive preset. Unambiguous sentinel
        # so codex's own subcommands (exec/login/...) never collide with cxp's.
        launch(args[1:], apply_preset=False)
    else:
        launch(args)


if __name__ == "__main__":
    main()
